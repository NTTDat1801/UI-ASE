PORT=8080
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=clms
DB_USERNAME=clms_user
DB_PASSWORD=123456

# Arduino IoT Cloud API (OAuth2) — from Cloud → Integrations → API Keys (never commit real secrets)
ARDUINO_CLIENT_ID=PQjMOh0ootAoe9Fk6cbPrYIYh42EKe7H
ARDUINO_CLIENT_SECRET=S5JN6YDIuQWxPteLCCNTH4uk88QVO23WIX0mzdEhiRqXcG2UKQazbyqHjkzEXagb

# Thing UUID = KidGuard child_id (ví dụ Thing hiện tại của bạn)
ARDUINO_THING_ID=cb184099-9a5c-4a47-a5cc-d712bff00f7a
ARDUINO_CHILD_ID=cb184099-9a5c-4a47-a5cc-d712bff00f7a

# Tự động đọc Cloud API và ghi DB định kỳ (ms). Mặc định 60000 = 1 phút. Đặt 0 để tắt.
ARDUINO_POLL_INTERVAL_MS=60000
ARDUINO_POLL_BOOT_DELAY_MS=5000

# Optional: if set, POST /api/sync/arduino-cloud must send header x-arduino-sync-token: <value>
ARDUINO_SYNC_TOKEN=

# Copy child_latest_location → location_history on this interval (ms). Code default is 60000 (1 min) for testing.
# After OK: set 3600000 (60 min). Set 0 to disable.
LOCATION_SNAPSHOT_INTERVAL_MS=60000

# First snapshot this many ms after server start (default 10000). Only runs if child_latest_location has rows.
LOCATION_SNAPSHOT_BOOT_DELAY_MS=10000
