DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=clms
DB_USERNAME=root
DB_PASSWORD=123456
PORT=8080

# --- Arduino Cloud (chỉ backend; KHÔNG đưa secret vào kidguard-ui) ---
# Lấy từ Arduino Cloud → Integrations → API credentials. Dán vào 2 dòng dưới:
ARDUINO_CLIENT_ID=
ARDUINO_CLIENT_SECRET=
# Thing ID = child_id trong DB / VITE_CHILD_ID (sửa nếu Thing khác):
ARDUINO_THING_ID=
ARDUINO_CHILD_ID=
# Poll Cloud → ghi DB mỗi 60 giây (0 = tắt):
ARDUINO_POLL_INTERVAL_MS=60000
ARDUINO_POLL_BOOT_DELAY_MS=5000
# Tắt snapshot trùng chu kỳ (để mỗi phút chỉ 1 lần ghi từ poll):
LOCATION_SNAPSHOT_INTERVAL_MS=0
